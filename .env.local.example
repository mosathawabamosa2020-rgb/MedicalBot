# Copy to .env.local and fill values
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/medical?schema=public
NEXTAUTH_SECRET=change_me_to_a_long_random_value
REDIS_URL=redis://localhost:6379

# AWS S3 / R2 placeholders
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Search API (SerpAPI or Google Custom Search)
SERPAPI_KEY=
GOOGLE_CSE_ID=
OPENAI_API_KEY=
EMBEDDING_BACKEND=local
VECTORSTORE_PROVIDER=local
